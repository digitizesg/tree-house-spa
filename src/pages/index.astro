---
import BaseLayout from "../layouts/BaseLayout.astro";
import Reviews from "../components/Reviews.astro";
import ServiceIcon from "../components/ServiceIcon.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/hero.png";

const services = [
  { name: "Body Massage", icon: "service-icon-1.png", tiers: [["60 min", "$65"], ["90 min", "$90"], ["120 min", "$115"]] },
  { name: "Essential Oils Massage", icon: "service-icon-3.png", tiers: [["60 min", "$72"], ["90 min", "$100"], ["120 min", "$130"]] },
  { name: "Foot Massage", icon: "service-icon-4.png", tiers: [["60 min", "$48"], ["90 min", "$68"], ["120 min", "$88"]] },
  { name: "Prenatal Massage", icon: "service-icon-5.png", tiers: [["60 min", "$65"], ["90 min", "$90"], ["120 min", "$115"]] },
  { name: "Body Scrub", icon: "service-icon-2.png", tiers: [["30 min", "$35"]] },
  { name: "Ear Candling", icon: "service-icon-6.png", tiers: [["30 min", "$35"]] },
];
---

<BaseLayout
  title="Tree House Spa | Massage on River Valley Road, Singapore"
  description="High quality body, foot, oil and prenatal massage at Tree House Spa, 238 River Valley Road. Trained therapists, affordable prices, open daily 10am to 10:30pm."
>
  <!-- Hero -->
  <section style="background:linear-gradient(180deg, var(--sand) 0%, var(--sand-deep) 100%);">
    <div class="container hero-grid" style="padding-block:clamp(3rem,7vw,5.5rem);">
      <div style="max-width:620px;">
        <div class="eyebrow">Massage &middot; River Valley, Singapore</div>
        <h1 style="margin:1rem 0 0;font-size:clamp(2.2rem,5.5vw,3.5rem);line-height:1.08;">
          High quality massage<br />on <span style="color:var(--moss);font-style:italic;">River Valley Road</span>
        </h1>
        <p style="margin-top:1.5rem;font-size:clamp(1.05rem,1.6vw,1.2rem);color:var(--ink-dim);line-height:1.65;max-width:52ch;">
          Our trained team has been providing massage services on River Valley Road for over 13 years. We provide massages to both men and women at highly affordable rates.
        </p>
        <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="tel:+6562356233" class="btn">Call to book</a>
          <a href="/services/" class="btn-ghost">See treatments</a>
        </div>
      </div>
      <Image src={heroImage} alt="Tree House Spa treatment room" class="hero-img" widths={[400, 600, 805]} sizes="(min-width:880px) 48vw, 92vw" loading="eager" fetchpriority="high" />
    </div>
  </section>

  <!-- Services -->
  <section id="services">
    <div class="container" style="padding-block:clamp(3.5rem,7vw,5.5rem);">
      <div class="eyebrow">Treatments</div>
      <h2 style="margin:0.75rem 0 0;font-size:clamp(1.8rem,3.5vw,2.6rem);">Our services</h2>
      <p style="margin:1rem 0 0;color:var(--ink-dim);max-width:54ch;line-height:1.6;">
        Treatments for men and women, by professionally trained therapists. Walk-ins are welcome, though booking ahead is best for your preferred time.
      </p>
      <div class="svc-grid">
        {services.map((s) => (
          <article class="svc-card">
            <div class="svc-card-head">
              <div class="svc-icon"><ServiceIcon name={s.name} size={32} /></div>
              <h3 style="margin:0;font-size:1.15rem;">{s.name}</h3>
            </div>
            <div>
              {s.tiers.map(([dur, price]) => (
                <div style="display:flex;justify-content:space-between;align-items:baseline;padding:0.5rem 0;border-top:1px solid var(--hair);">
                  <span style="color:var(--ink-dim);font-size:0.95rem;">{dur}</span>
                  <span style="font-weight:700;color:var(--moss);">{price}</span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
      <div style="margin-top:2rem;">
        <a href="/services/" class="btn-ghost">See full treatment details &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Reviews (hidden until reviews.json is populated) -->
  <Reviews />

  <!-- Visit -->
  <section id="visit">
    <div class="container" style="padding-block:clamp(3.5rem,7vw,5.5rem);display:grid;gap:2.5rem;align-items:center;grid-template-columns:repeat(auto-fit,minmax(min(100%,280px),1fr));">
      <div>
        <div class="eyebrow">Visit us</div>
        <h2 style="margin:0.75rem 0 1.25rem;font-size:clamp(1.7rem,3.2vw,2.3rem);">Drop by or call ahead</h2>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="tel:+6562356233" class="btn">Call +65 6235 6233</a>
          <a href="https://www.google.com/maps/dir/?api=1&destination=Tree+House+Spa&destination_place_id=ChIJh9kHG5kZ2jER7YWaAoay7Ps" target="_blank" rel="noopener" class="btn-ghost">Get directions</a>
        </div>
        <div style="margin-top:1.75rem;font-size:1rem;color:var(--ink-dim);line-height:1.9;">
          <div><strong style="color:var(--bark);">Address</strong><br />238 River Valley Road<br />Singapore 238296</div>
          <div style="margin-top:1rem;"><strong style="color:var(--bark);">Phone</strong><br /><a href="tel:+6562356233" style="color:inherit;text-decoration:none;">+65 6235 6233</a> &middot; <a href="tel:+6590018721" style="color:inherit;text-decoration:none;">+65 9001 8721</a></div>
          <div style="margin-top:1rem;"><strong style="color:var(--bark);">Open</strong><br />Daily, 10am to 10:30pm</div>
        </div>
      </div>
      <div style="border-radius:16px;overflow:hidden;border:1px solid var(--hair);box-shadow:0 12px 30px rgba(0,0,0,0.08);">
        <iframe
          title="Tree House Spa on Google Maps — 238 River Valley Road, Singapore"
          src="https://maps.google.com/maps?q=Tree+House+Spa,+238+River+Valley+Road,+Singapore+238296&z=16&output=embed"
          width="100%"
          height="100%"
          style="border:0;display:block;min-height:380px;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
