---
import BaseLayout from "../layouts/BaseLayout.astro";

// Real services + pricing from the current site (treehousespa.com.sg).
const services = [
  { name: "Body Massage", tiers: [["60 min", "$65"], ["90 min", "$90"], ["120 min", "$115"]] },
  { name: "Essential Oils Massage", tiers: [["60 min", "$72"], ["90 min", "$100"], ["120 min", "$130"]] },
  { name: "Foot Massage", tiers: [["60 min", "$48"], ["90 min", "$68"], ["120 min", "$88"]] },
  { name: "Prenatal Massage", tiers: [["60 min", "$65"], ["90 min", "$90"], ["120 min", "$115"]] },
  { name: "Body Scrub", tiers: [["30 min", "$35"]] },
  { name: "Ear Candling", tiers: [["30 min", "$35"]] },
];
---

<BaseLayout
  title="Tree House Spa | Massage on River Valley Road, Singapore"
  description="High quality body, foot, oil and prenatal massage at Tree House Spa, 238 River Valley Road. Trained therapists, affordable prices, open daily 10am to 10:30pm."
>
  <!-- Hero -->
  <section style="background:linear-gradient(180deg, var(--sand) 0%, var(--sand-deep) 100%);">
    <div class="container" style="padding-block:clamp(3rem,7vw,5.5rem);display:grid;gap:2.5rem;grid-template-columns:1fr;align-items:center;">
      <div style="max-width:620px;">
        <div class="eyebrow">Massage &middot; River Valley, Singapore</div>
        <h1 style="margin:1rem 0 0;font-size:clamp(2.2rem,5.5vw,3.5rem);line-height:1.08;">
          High quality massage,<br /><span style="color:var(--moss);font-style:italic;">at honest prices.</span>
        </h1>
        <p style="margin-top:1.5rem;font-size:clamp(1.05rem,1.6vw,1.2rem);color:var(--ink-dim);line-height:1.65;max-width:52ch;">
          A calm, spotless retreat on River Valley Road. Trained therapists, treatments for men and women, and more than twelve years of looking after our guests.
        </p>
        <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="tel:+6562356233" class="btn">Call to book</a>
          <a href="/#services" class="btn-ghost">See treatments</a>
        </div>
      </div>
      <img src="/images/hero.png" alt="Tree House Spa treatment room" loading="eager"
        style="width:100%;height:auto;border-radius:20px;display:block;" />
    </div>
  </section>

  <!-- Services -->
  <section id="services">
    <div class="container" style="padding-block:clamp(3.5rem,7vw,5.5rem);">
      <div class="eyebrow">Treatments &amp; prices</div>
      <h2 style="margin:0.75rem 0 0;font-size:clamp(1.8rem,3.5vw,2.6rem);">Our menu</h2>
      <p style="margin:1rem 0 0;color:var(--ink-dim);max-width:54ch;line-height:1.6;">
        Prices are per person. Walk-ins are welcome, though booking ahead is best for your preferred time.
      </p>
      <div style="margin-top:2.5rem;display:grid;gap:1.25rem;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));">
        {services.map((s) => (
          <article style="background:var(--cream);border:1px solid var(--hair);border-radius:16px;padding:1.6rem 1.75rem;">
            <h3 style="margin:0 0 1rem;font-size:1.2rem;">{s.name}</h3>
            {s.tiers.map(([dur, price]) => (
              <div style="display:flex;justify-content:space-between;align-items:baseline;padding:0.45rem 0;border-top:1px solid var(--hair);">
                <span style="color:var(--ink-dim);font-size:0.95rem;">{dur}</span>
                <span style="font-weight:700;color:var(--moss);">{price}</span>
              </div>
            ))}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" style="background:var(--sand-deep);">
    <div class="container" style="padding-block:clamp(3.5rem,7vw,5.5rem);max-width:680px;">
      <div class="eyebrow">Who we are</div>
      <h2 style="margin:0.75rem 0 0;font-size:clamp(1.8rem,3.5vw,2.6rem);">Twelve years of good hands</h2>
      <p style="margin-top:1.5rem;color:var(--ink-dim);font-size:1.05rem;line-height:1.7;">
        Tree House Spa has been on River Valley Road for over twelve years, offering high quality massage for men and women
        at affordable prices. Every therapist is a trained professional, and we hold a high standard of cleanliness throughout,
        so every visit feels calm, private and properly looked after.
      </p>
    </div>
  </section>

  <!-- Visit -->
  <section id="visit">
    <div class="container" style="padding-block:clamp(3.5rem,7vw,5.5rem);display:grid;gap:2rem;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));">
      <div>
        <div class="eyebrow">Visit us</div>
        <h2 style="margin:0.75rem 0 1.25rem;font-size:clamp(1.7rem,3.2vw,2.3rem);">Drop by or call ahead</h2>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="tel:+6562356233" class="btn">Call +65 6235 6233</a>
          <a href="https://maps.google.com/?q=238+River+Valley+Road+Singapore+238296" target="_blank" rel="noopener" class="btn-ghost">Get directions</a>
        </div>
      </div>
      <div style="font-size:1rem;color:var(--ink-dim);line-height:1.9;">
        <div><strong style="color:var(--bark);">Address</strong><br />238 River Valley Road<br />Singapore 238296</div>
        <div style="margin-top:1rem;"><strong style="color:var(--bark);">Phone</strong><br />+65 6235 6233 &middot; +65 9001 8721</div>
        <div style="margin-top:1rem;"><strong style="color:var(--bark);">Open</strong><br />Daily, 10am to 10:30pm</div>
      </div>
    </div>
  </section>
</BaseLayout>
