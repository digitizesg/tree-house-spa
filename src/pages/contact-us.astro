---
import BaseLayout from "../layouts/BaseLayout.astro";
const inputCss =
  "width:100%;padding:0.7rem 0.85rem;border:1px solid var(--hair);border-radius:10px;background:var(--cream);color:var(--bark);font:inherit;";
---

<BaseLayout
  title="Contact us | Tree House Spa, River Valley"
  description="Get in touch with Tree House Spa at 238 River Valley Road, Singapore. Call +65 6235 6233, open daily 10am to 10:30pm, or send us a message."
  canonical="/contact-us/"
>
  <section style="background:linear-gradient(180deg, var(--sand) 0%, var(--sand-deep) 100%);">
    <div class="container" style="padding-block:clamp(3rem,7vw,4.5rem);">
      <div style="max-width:680px;">
        <div class="eyebrow">Contact us</div>
        <h1 style="margin:1rem 0 0;font-size:clamp(2.2rem,5vw,3.2rem);line-height:1.08;">Get in touch</h1>
        <p style="margin-top:1.25rem;font-size:1.1rem;color:var(--ink-dim);line-height:1.7;">
          Get in touch or drop by to enjoy a relaxing massage at Tree House Spa.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="container" style="padding-block:clamp(2.5rem,6vw,4.5rem);display:grid;gap:2.5rem;grid-template-columns:repeat(auto-fit,minmax(min(100%,280px),1fr));align-items:start;">
      <!-- Details + map -->
      <div>
        <div style="font-size:1rem;color:var(--ink-dim);line-height:1.9;">
          <div><strong style="color:var(--bark);">Address</strong><br />238 River Valley Road<br />Singapore 238296</div>
          <div style="margin-top:1rem;"><strong style="color:var(--bark);">Phone</strong><br />
            <a href="tel:+6562356233" style="color:var(--moss);font-weight:600;">+65 6235 6233</a> &middot;
            <a href="tel:+6590018721" style="color:var(--moss);font-weight:600;">+65 9001 8721</a>
          </div>
          <div style="margin-top:1rem;"><strong style="color:var(--bark);">Open</strong><br />Daily, 10am to 10:30pm</div>
        </div>
        <iframe
          title="Map to Tree House Spa, 238 River Valley Road"
          src="https://maps.google.com/maps?q=Tree+House+Spa,+238+River+Valley+Road,+Singapore+238296&z=16&output=embed"
          loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          style="margin-top:1.5rem;width:100%;height:300px;border:0;border-radius:16px;"></iframe>
      </div>

      <!-- Form -->
      <div style="background:var(--cream);border:1px solid var(--hair);border-radius:18px;padding:1.75rem;">
        <h2 style="margin:0 0 1.25rem;font-size:1.4rem;">Send us a message</h2>
        <form id="contact-form" method="post" action="/api/contact" style="display:flex;flex-direction:column;gap:1rem;">
          <label style="display:block;">
            <span style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.35rem;">Your name</span>
            <input name="name" type="text" required autocomplete="name" style={inputCss} />
          </label>
          <label style="display:block;">
            <span style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.35rem;">Your phone number</span>
            <input name="phone" type="tel" required autocomplete="tel" style={inputCss} />
          </label>
          <label style="display:block;">
            <span style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.35rem;">Your email</span>
            <input name="email" type="email" required autocomplete="email" style={inputCss} />
          </label>
          <label style="display:block;">
            <span style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.35rem;">Your message <span style="color:var(--ink-mute);font-weight:400;">(optional)</span></span>
            <textarea name="message" rows="4" style={inputCss}></textarea>
          </label>
          <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;width:1px;height:1px;padding:0;border:0;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);" />
          <button type="submit" class="btn" style="justify-content:center;">Send message</button>
          <p id="form-status" role="status" style="margin:0;font-size:0.9rem;min-height:1.2em;"></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const data = Object.fromEntries(new FormData(form).entries());
      status.style.color = "var(--ink-dim)";
      status.textContent = "Sending…";
      if (btn) btn.disabled = true;
      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(data),
        });
        const out = await res.json().catch(() => ({}));
        if (res.ok && out.ok) {
          form.reset();
          status.style.color = "var(--moss)";
          status.textContent = "Thank you. We'll be in touch shortly.";
        } else {
          status.style.color = "#a23b2c";
          status.textContent = "Sorry, that didn't send. Please call us on +65 6235 6233.";
        }
      } catch {
        status.style.color = "#a23b2c";
        status.textContent = "Sorry, that didn't send. Please call us on +65 6235 6233.";
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  }
</script>
