---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import reviews from "../data/reviews.json";

interface Props {
  title: string;
  description: string;
  /** Path-only canonical, e.g. "/services/". Defaults to the current path. */
  canonical?: string;
}

const SITE_NAME = "Tree House Spa";
const { title, description, canonical } = Astro.props;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-image.jpg", Astro.site);

// Sitewide LocalBusiness structured data for local search / rich results.
const businessSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "DaySpa",
  "@id": new URL("/#business", Astro.site).href,
  name: SITE_NAME,
  url: new URL("/", Astro.site).href,
  image: ogImage.href,
  logo: new URL("/images/ths-logo.svg", Astro.site).href,
  telephone: "+6562356233",
  priceRange: "$$",
  currenciesAccepted: "SGD",
  address: {
    "@type": "PostalAddress",
    streetAddress: "238 River Valley Road",
    addressLocality: "Singapore",
    postalCode: "238296",
    addressCountry: "SG",
  },
  geo: { "@type": "GeoCoordinates", latitude: 1.2941088, longitude: 103.8424108 },
  hasMap: "https://www.google.com/maps/place/?q=place_id:ChIJh9kHG5kZ2jER7YWaAoay7Ps",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "10:00",
      closes: "22:30",
    },
  ],
};
if (reviews?.rating && reviews?.count) {
  businessSchema.aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: reviews.rating,
    reviewCount: reviews.count,
    bestRating: 5,
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#5B7553" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_SG" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE_NAME} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
