---
// TODO: confirm nav items once the page structure is set.
const links = [
  { href: "/services/", label: "Services" },
  { href: "/who-we-are/", label: "Who we are" },
  { href: "/contact-us/", label: "Contact us" },
];
---

<header style="position:sticky;top:0;z-index:50;background:color-mix(in srgb, var(--sand) 88%, transparent);backdrop-filter:blur(8px);border-bottom:1px solid var(--hair);">
  <div style="background:var(--moss);color:var(--sand);">
    <div class="container" style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:0.25rem 1.5rem;padding-block:0.5rem;font-size:0.85rem;text-align:center;">
      <span>Call us:
        <a href="tel:+6562356233" style="color:var(--sand);font-weight:700;">+65 6235 6233</a>
        or
        <a href="tel:+6590018721" style="color:var(--sand);font-weight:700;">+65 9001 8721</a>
      </span>
      <span style="opacity:0.55;">|</span>
      <span><strong style="font-weight:700;">Open</strong> 10am to 10:30pm, every day</span>
    </div>
  </div>
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:68px;">
    <a href="/" aria-label="Tree House Spa home" style="display:flex;align-items:center;">
      <img src="/images/ths-logo.svg" alt="Tree House Spa" style="height:34px;width:auto;display:block;" />
    </a>
    <nav style="display:flex;align-items:center;gap:1.75rem;">
      {links.map((l) => (
        <a href={l.href} style="font-size:0.95rem;color:var(--ink-dim);">{l.label}</a>
      ))}
      <a href="tel:+6562356233" class="btn">Call to book</a>
    </nav>
  </div>
</header>
