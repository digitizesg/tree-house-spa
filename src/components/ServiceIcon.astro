---
// Consistent line icons for each treatment, drawn in the brand green.
// Keyed by the exact service name used on the homepage and /services/.
interface Props { name: string; size?: number }
const { name, size = 38 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor"
  stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
  style="color:var(--moss);display:block;" aria-hidden="true">
  {name === "Body Massage" && (
    <Fragment>
      <ellipse cx="12" cy="17.3" rx="7" ry="2.4" />
      <ellipse cx="12" cy="12.2" rx="5.4" ry="2.1" />
      <ellipse cx="12" cy="7.4" rx="3.9" ry="1.8" />
    </Fragment>
  )}
  {name === "Essential Oils Massage" && (
    <Fragment>
      <path d="M12 3.4c3 3.6 6 6.9 6 10.3a6 6 0 1 1-12 0c0-3.4 3-6.7 6-10.3Z" />
      <path d="M9.6 14.3a2.4 2.4 0 0 0 2.4 2.4" />
    </Fragment>
  )}
  {name === "Foot Massage" && (
    <Fragment>
      <ellipse cx="11.5" cy="14.8" rx="4.4" ry="5.4" />
      <circle cx="7.6" cy="7.2" r="0.9" />
      <circle cx="9.9" cy="6.1" r="0.9" />
      <circle cx="12.3" cy="6.1" r="0.9" />
      <circle cx="14.4" cy="7.3" r="0.9" />
    </Fragment>
  )}
  {name === "Prenatal Massage" && (
    <path d="M12 20s-6.5-4.2-6.5-9.1A3.6 3.6 0 0 1 12 8.4a3.6 3.6 0 0 1 6.5 2.5C18.5 15.8 12 20 12 20Z" />
  )}
  {name === "Body Scrub" && (
    <Fragment>
      <path d="M12 3.8 13.3 10.7 20.2 12 13.3 13.3 12 20.2 10.7 13.3 3.8 12 10.7 10.7Z" />
      <circle cx="18.4" cy="5.8" r="0.85" />
    </Fragment>
  )}
  {name === "Ear Candling" && (
    <Fragment>
      <rect x="9.6" y="9.5" width="4.8" height="10.5" rx="1" />
      <line x1="12" y1="9.5" x2="12" y2="7" />
      <path d="M12 7c1.3-.9 1.3-2.4 0-3.8-1.3 1.4-1.3 2.9 0 3.8Z" />
      <line x1="10.7" y1="13" x2="13.3" y2="13" />
    </Fragment>
  )}
</svg>
